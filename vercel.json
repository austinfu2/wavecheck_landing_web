{
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [{ "key": "Content-Type", "value": "application/json" }]
    }
  ],
  "rewrites": [
    { "source": "/spot/:id", "destination": "/app-redirect.html" },
    { "source": "/forecast/:id", "destination": "/app-redirect.html" }
  ]
}
